{
  "rewrites": [
    {
      "source": "/api/v1/(.*)",
      "destination": "https://milan-portfolio-api.up.railway.app/api/v1/$1"
    }
  ],
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        {
          "key": "X-Content-Type-Options",
          "value": "nosniff"
        },
        {
          "key": "X-Frame-Options",
          "value": "DENY"
        }
      ]
    }
  ],
  "regions": ["sin1"]
}
